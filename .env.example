# Supabase — vul deze in nadat het project is aangemaakt (zie README)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Voetbaldata-API (gratis tier op https://www.football-data.org/)
# Gebruikt door de Supabase Edge Function "sync-results"
FOOTBALL_DATA_API_KEY=your-football-data-api-token
# Competitie-code van het toernooi (WK = "WC")
FOOTBALL_DATA_COMPETITION=WC
